# ── API Gateway ──
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*
ALLOWED_HOSTS=*
DEBUG=false

# ── Database ──
DATABASE_URL=sqlite:///rag.db
# DATABASE_URL=postgresql+asyncpg://rag:ragpass@localhost:5432/ragdb
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300
REDIS_SEMANTIC_THRESHOLD=0.92

# ── Qdrant ──
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_documents
QDRANT_VECTOR_SIZE=384

# ── S3 / MinIO ──
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=rag-documents

# ── JWT ──
JWT_SECRET=change-me-in-production-rag-system-2024
JWT_ACCESS_EXPIRE_SECONDS=3600
JWT_REFRESH_EXPIRE_SECONDS=2592000

# ── LLM / Ollama ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=60
GROQ_API_KEY=
PREFERRED_MODELS=phi3:mini,phi4,llama3.2,gemma4,gemma3,llama3.2:1b,tinyllama,mistral
MAX_MODEL_SIZE_GB=5.0
MAX_CONTEXT_CHARS=6000
RETRIEVAL_K=3

# ── Celery ──
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Monitoring ──
OTLP_ENDPOINT=
SENTRY_DSN=

# ── Backward Compatible ──
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=langchain
TRANSFORMER_CHECKPOINT=transformer_best.pth
LOG_LEVEL=INFO
RAG_LOG_LEVEL=INFO
